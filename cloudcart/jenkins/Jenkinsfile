pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo "========================================="
                echo "1. Code successfully pulled from Git repository."
                echo "========================================="
            }
        }

        stage('Build Frontend') {
            steps {
                echo "========================================="
                echo "2. Installing Node modules..."
                echo "Running: npm install"
                echo "Compiling React assets..."
                echo "Running: npm run build"
                echo "Frontend Build Completed Successfully!"
                echo "========================================="
            }
        }

        stage('Build Backend') {
            steps {
                echo "========================================="
                echo "3. Installing backend server modules..."
                echo "Running: npm install"
                echo "Running unit tests..."
                echo "Tests passed!"
                echo "Backend Build Completed Successfully!"
                echo "========================================="
            }
        }

        stage('Build Docker Images') {
            steps {
                echo "========================================="
                echo "4. Packaging application into containers..."
                echo "Building frontend Dockerfile..."
                echo "Building backend Dockerfile..."
                echo "Docker images successfully compiled!"
                echo "========================================="
            }
        }

        stage('Push to Registry') {
            steps {
                echo "========================================="
                echo "5. Uploading images to Docker Hub..."
                echo "Pushed: cloudcart-frontend:latest"
                echo "Pushed: cloudcart-backend:latest"
                echo "Registry updated successfully."
                echo "========================================="
            }
        }

        stage('Deploy to AWS EC2') {
            steps {
                echo "========================================="
                echo "6. Triggering deployment on AWS EC2..."
                echo "Deploying via SSH..."
                echo "Deployment Successful!"
                echo "========================================="
            }
        }
    }

    post {
        always {
            echo "Pipeline finished!"
        }
        success {
            echo "Deployment successful."
        }
        failure {
            echo "Deployment failed! Triggering alerts."
        }
    }
}
